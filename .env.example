# Local algo_trader environment template.
# Copy to .env for local-only use and replace placeholders there.
# Never put real secrets in this tracked example file.

# Core local configuration
APP_PROFILE=
LOG_LEVEL=
DATA_DIR=
STARTING_CASH=
PAPER_EXCHANGE=

# Explicitly gated Alpaca paper integration settings
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_BASE_URL=

# Explicitly gated test/network opt-in flags
RUN_ALPACA_PAPER_INTEGRATION_TESTS=
ALGO_TRADER_ALLOW_NETWORK_TESTS=

# Explicitly gated Alpaca Market Data research fetcher settings
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
